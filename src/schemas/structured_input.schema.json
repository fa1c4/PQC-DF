{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pqcfuzz.local/schemas/structured_input.schema.json",
  "type": "object",
  "required": [
    "magic",
    "version",
    "algorithm",
    "oracle_id",
    "flags",
    "seed_len",
    "msg_len",
    "mutation_len",
    "extra_len"
  ],
  "properties": {
    "magic": {
      "const": "PQCF"
    },
    "version": {
      "type": "integer"
    },
    "algorithm": {
      "enum": [
        "ML-KEM-512",
        "ML-KEM-768",
        "ML-KEM-1024",
        "ML-DSA-44",
        "ML-DSA-65",
        "ML-DSA-87",
        "SLH-DSA-SHA2-128s",
        "SLH-DSA-SHAKE-128s",
        "SLH-DSA-SHA2-128f",
        "SLH-DSA-SHAKE-128f",
        "SLH-DSA-SHA2-192s",
        "SLH-DSA-SHAKE-192s",
        "SLH-DSA-SHA2-192f",
        "SLH-DSA-SHAKE-192f",
        "SLH-DSA-SHA2-256s",
        "SLH-DSA-SHAKE-256s",
        "SLH-DSA-SHA2-256f",
        "SLH-DSA-SHAKE-256f"
      ]
    },
    "oracle_id": {
      "type": "string"
    },
    "flags": {
      "type": "integer"
    }
  }
}
